# Wiki Notebook Configuration
# Copy to .env and adjust values for your deployment.
# All variables are optional — defaults shown below.

# Server binding (use 0.0.0.0 for LAN access)
BIND_HOST=127.0.0.1
PORT=5000

# Database
DB_PATH=./data/notebook.db

# Ollama AI integration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=30

# AI writing style for note optimization
OPTIMIZE_TONE=balanced, professional, clear
