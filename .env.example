# Bind host — 127.0.0.1 for localhost-only (default), 0.0.0.0 for LAN
BIND_HOST=127.0.0.1
PORT=5000

# SQLite database path
DB_PATH=./data/notebook.db

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=30

# Optimize tone (for Session 7)
OPTIMIZE_TONE=balanced, professional, clear
